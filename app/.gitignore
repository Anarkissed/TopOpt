# CMake build tree for the vendored core static lib (build_core.sh output)
.build-core/

# Cross-compiled iOS OCCT/lib3mf tree (build_occt_ios.sh output: sources, build
# dirs, per-slice install prefixes, staged frameworks). Regenerated, huge, and
# machine-specific; never committed. The resulting xcframeworks land under
# TopOptKit/vendor/ (already ignored below).
.build-occt-ios/

# Vendored core + OCCT (regenerated by scripts/build_core.sh; never committed)
TopOptKit/vendor/

# Generated iOS OCCT/lib3mf framework list read by Package.swift at manifest-eval
# time (written by scripts/build_occt_ios.sh; per-machine, never committed — the
# committed default is "absent" == OCCT-free). See run 039 / M7.1c.
TopOptKit/occt-frameworks.generated.json

# Generated core build fingerprint (the git SHA the vendored core was built from),
# written by scripts/build_core.sh with the SAME derivation the CLI's CMake uses.
# Gitignored for the same reason as vendor/ above: build_core.sh already MUST run
# before the app builds (it produces the vendored xcframework this file pairs with),
# so regenerating the fingerprint is not a new step. See handoff 097.
TopOptKit/Sources/TopOptFlows/CoreFingerprint.generated.swift

# SwiftPM / Xcode build products
TopOptKit/.build/
.swiftpm/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
DerivedData/
build/
